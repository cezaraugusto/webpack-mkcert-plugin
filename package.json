{
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cezaraugusto/webpack-mkcert-plugin.git"
  },
  "engines": {
    "node": ">=18"
  },
  "name": "webpack-mkcert-plugin",
  "version": "0.1.2",
  "description": "Use certificates for webpack that are trusted by your local machine, avoiding browser security warnings during development.",
  "main": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "files": [
    "dist"
  ],
  "author": {
    "name": "Cezar Augusto",
    "email": "boss@cezaraugusto.net",
    "url": "https://cezaraugusto.com"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "watch": "yarn compile --watch",
    "compile": "tsup-node ./module.ts --format cjs --dts --target=node18 --minify",
    "lint": "eslint .",
    "pretest": "pnpm run compile",
    "test": "jest",
    "prepublishOnly": "pnpm run clean && pnpm run compile",
    "lint:fix": "eslint . --fix"
  },
  "publishConfig": {
    "provenance": true
  },
  "keywords": [
    "webpack",
    "plugin",
    "mkcert",
    "cert",
    "certificate",
    "https"
  ],
  "peerDependencies": {
    "webpack": "^5.0.0"
  },
  "dependencies": {
    "@colors/colors": "^1.6.0",
    "semver-compare": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^18.11.9",
    "@types/semver-compare": "^1.0.1",
    "eslint": "^10.5.0",
    "eslint-config-auditor": "^1.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "tsconfig": "*",
    "tsup": "^8.0.1",
    "typescript": "^5.8.3",
    "webpack": "~5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "packageManager": "pnpm@9.9.0",
  "bugs": "https://github.com/cezaraugusto/webpack-mkcert-plugin/issues",
  "homepage": "https://github.com/cezaraugusto/webpack-mkcert-plugin#readme",
  "pnpm": {
    "overrides": {
      "vite": ">=7.3.5",
      "vitest": ">=3.2.6",
      "rollup": ">=4.59.0",
      "minimatch": ">=9.0.7",
      "picomatch": ">=4.0.4",
      "postcss": ">=8.5.10",
      "js-yaml": ">=4.2.0",
      "brace-expansion": ">=2.0.2",
      "tmp": ">=0.2.6",
      "esbuild": ">=0.25.0",
      "webpack": ">=5.104.1"
    }
  }
}
